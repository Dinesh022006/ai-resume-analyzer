generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id         String     @id @default(uuid())
  userId     String
  title      String
  fileName   String
  parsedText String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  analyses   Analysis[]

  @@index([userId])
  @@index([createdAt])
}

model Analysis {
  id                     String   @id @default(uuid())
  resumeId               String
  atsScore               Int
  overallRating          String
  summary                String
  strengths              Json
  weaknesses             Json
  missingTechnicalSkills Json
  missingSoftSkills      Json
  grammarIssues          Json
  formattingSuggestions  Json
  improvementSuggestions Json
  recommendedJobRoles    Json
  jobDescription         String?
  jobMatchScore          Int?
  createdAt              DateTime @default(now())
  resume                 Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([createdAt])
}
